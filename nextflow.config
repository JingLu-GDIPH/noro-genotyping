// Nextflow configuration file for Norovirus Genotyping Pipeline

// Process configuration
process {
    // Default resource limits
    cpus = 4
    memory = '4 GB'
    time = '2h'
    
    // Error handling
    errorStrategy = 'retry'
    maxRetries = 3
    
    // Resource allocation based on process
    withName: 'NOROVIRUS_GENOTYPING' {
        cpus = 8
        memory = '8 GB'
        time = '4h'
    }
    
    withName: 'MERGE_RESULTS' {
        cpus = 2
        memory = '2 GB'
        time = '30m'
    }
}

// Execution configuration
executor {
    name = 'local'
    queueSize = 100
}

// Conda configuration
conda {
    enabled = true
    cacheDir = 'conda'
}

// Docker configuration (alternative to conda)
docker {
    enabled = false
    runOptions = '-u $(id -u):$(id -g)'
}

// Reporting
report {
    enabled = true
    file = 'pipeline_report.html'
}

// Timeline
timeline {
    enabled = true
    file = 'timeline_report.html'
}

// Trace
trace {
    enabled = true
    file = 'trace.txt'
}

// Manifest
manifest {
    name = 'norovirus-typing'
    author = 'Bioinformatics Team'
    description = 'Norovirus GI/GII classification and dual-region phylogenetic genotyping'
    version = '2.2.0'
    nextflowVersion = '>=20.0.0'
}

// Profiles for different execution environments
profiles {
    // Local execution
    local {
        executor.name = 'local'
        process.cpus = 4
        process.memory = '4 GB'
    }
    
    // High-performance computing
    hpc {
        executor.name = 'slurm'
        executor.queueSize = 100
        process.cpus = 8
        process.memory = '16 GB'
        process.time = '6h'
    }
    
    // Cloud execution
    cloud {
        executor.name = 'awsbatch'
        executor.queueSize = 50
        process.cpus = 4
        process.memory = '8 GB'
    }
    
    // Debug mode
    debug {
        process.cpus = 1
        process.memory = '2 GB'
        process.time = '1h'
        log.level = 'debug'
    }
} 
